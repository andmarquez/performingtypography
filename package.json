{
  "name": "andsiosas-creative-quest",
  "version": "1.0.0",
  "description": "Andsiosa's Creative Quest — a cute retro side-scrolling platformer built with Phaser, Vite, and TypeScript",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "phone:tunnel": "bash scripts/phone-tunnel.sh"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2",
    "vite": "^8.0.14"
  },
  "private": true,
  "type": "module"
}
